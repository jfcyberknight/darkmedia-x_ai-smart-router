{
  "name": "@jfcyberknight/ai-smart-router",
  "version": "2.0.26",
  "description": "API Vercel qui route les requêtes IA vers Gemini, Groq et autres providers avec fallback automatique",
  "packageManager": "pnpm@9.1.0+",
  "main": "lib/router.js",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jfcyberknight/darkmedia-x_api-ai-smart-router.git"
  },
  "scripts": {
    "start:local": "vercel dev",
    "deploy": "vercel --prod",
    "prepare": "node scripts/install-git-hooks.js",
    "env:push": "node scripts/vercel-env-push.js",
    "env:sync": "node scripts/env-sync.js",
    "env:sync:force": "node scripts/env-sync.js --force",
    "test": "node --test tests/validate-chat.test.js tests/auth.test.js tests/deployed.test.js",
    "test:deployed": "node --test tests/deployed.test.js",
    "test:providers": "node scripts/test-providers.js",
    "test:api": "node scripts/test-api.js",
    "test:api:prod": "node scripts/test-api-deployed.js"
  },
  "keywords": [
    "ai",
    "vercel",
    "gemini",
    "groq",
    "router",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cookie": "^1.1.1",
    "jsonwebtoken": "^9.0.3"
  }
}
