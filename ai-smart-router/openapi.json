{
  "openapi": "3.0.3",
  "info": {
    "title": "DarkMedia-X | AI Smart Router",
    "description": "API Gateway for multiple AI providers with automatic load balancing and fallback.",
    "version": "2.0.26",
    "contact": {
      "name": "DarkMedia-X",
      "url": "https://darkmedia-x.com"
    }
  },
  "servers": [
    {
      "url": "https://darkmedia-x-ai-smart-router.vercel.app",
      "description": "Production server"
    },
    {
      "url": "http://localhost:3000",
      "description": "Local development"
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      },
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "Envelope": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "nullable": true,
            "example": "req-a1b2c3d4"
          },
          "statut": {
            "type": "string",
            "enum": [
              "actif",
              "inactif",
              "erreur"
            ]
          },
          "message": {
            "type": "string",
            "example": "Succès"
          },
          "donnees": {
            "type": "object",
            "nullable": true
          }
        }
      },
      "ChatMessage": {
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "user",
              "assistant",
              "system"
            ]
          },
          "content": {
            "type": "string"
          }
        }
      },
      "ChatRequest": {
        "type": "object",
        "required": [
          "messages"
        ],
        "properties": {
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChatMessage"
            }
          },
          "models": {
            "type": "object",
            "description": "Override models per provider",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "ChatResponse": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "model": {
            "type": "string"
          }
        }
      },
      "NormalizeRequest": {
        "type": "object",
        "required": [
          "text"
        ],
        "properties": {
          "text": {
            "type": "string",
            "maxLength": 32768
          }
        }
      }
    }
  },
  "paths": {
    "/api/health": {
      "get": {
        "tags": ["System"],
        "summary": "Health Check",
        "description": "Returns the service status and active providers.",
        "responses": {
          "200": {
            "description": "Service is operational",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "donnees": {
                          "type": "object",
                          "properties": {
                            "ok": {
                              "type": "boolean"
                            },
                            "service": {
                              "type": "string"
                            },
                            "providers": {
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/chat": {
      "post": {
        "tags": ["AI Operations"],
        "summary": "Chat Completion",
        "description": "Route a chat request to an AI provider with fallback logic.",
        "security": [
          {
            "BearerAuth": []
          },
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "donnees": {
                          "$ref": "#/components/schemas/ChatResponse"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/normalize": {
      "post": {
        "tags": ["AI Operations"],
        "summary": "Text Normalization",
        "description": "Extract structured data from free-text.",
        "security": [
          {
            "BearerAuth": []
          },
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NormalizeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Data successfully extracted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Envelope"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  }
}
