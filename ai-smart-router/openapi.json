{
  "openapi": "3.0.3",
  "info": {
    "title": "DarkMedia-X | AI Smart Router",
    "description": "API Gateway for multiple AI providers with automatic load balancing and fallback.",
    "version": "2.0.26",
    "contact": {
      "name": "DarkMedia-X",
      "url": "https://darkmedia-x.com"
    }
  },
  "servers": [
    {
      "url": "https://darkmedia-xapi-ai-smart-router.vercel.app",
      "description": "Production server"
    },
    {
      "url": "http://localhost:3000",
      "description": "Local development"
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Alternative auth if not logged in via Google OAuth."
      }
    },
    "schemas": {
      "Meta": {
        "type": "object",
        "properties": {
          "requestId": {
            "type": "string",
            "example": "req-a1b2c3d4"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-25T12:34:56.789Z"
          },
          "message": {
            "type": "string",
            "example": "Succès"
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "type": "object",
            "nullable": true
          },
          "meta": {
            "$ref": "#/components/schemas/Meta"
          }
        }
      },
      "ErrorDetail": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "VALIDATION_ERROR"
          },
          "message": {
            "type": "string",
            "example": "Le champ 'prompt' est requis."
          },
          "details": {
            "type": "object",
            "nullable": true,
            "example": { "field": "prompt", "reason": "required" }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "$ref": "#/components/schemas/ErrorDetail"
          },
          "meta": {
            "$ref": "#/components/schemas/Meta"
          }
        }
      },
      "ChatMessage": {
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "user",
              "assistant",
              "system"
            ],
            "example": "user"
          },
          "content": {
            "type": "string",
            "example": "Explique les microservices en une phrase."
          }
        }
      },
      "ChatRequest": {
        "type": "object",
        "required": [
          "messages"
        ],
        "properties": {
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChatMessage"
            },
            "example": [
              { "role": "user", "content": "Explique les microservices en une phrase." }
            ]
          },
          "model": {
            "type": "string",
            "description": "Model override. Default: meta-llama/llama-3.1-70b-instruct. If rate-limited, falls back automatically to free models.",
            "example": "meta-llama/llama-3.1-70b-instruct"
          }
        }
      },
      "ChatResponse": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "example": "Les microservices sont une architecture logicielle qui structure une application comme un ensemble de services faiblement couplés."
          },
          "provider": {
            "type": "string",
            "example": "openrouter"
          },
          "model": {
            "type": "string",
            "example": "meta-llama/llama-3.3-70b-instruct:free"
          }
        }
      },
      "NormalizeRequest": {
        "type": "object",
        "required": [
          "text"
        ],
        "properties": {
          "text": {
            "type": "string",
            "maxLength": 32768,
            "example": "L'utilisateur Jean Dupont a fini son test avec 85% aujourd'hui le 13 mars 2026."
          }
        }
      },
      "ImageRequest": {
        "type": "object",
        "required": ["prompt"],
        "properties": {
          "prompt": {
            "type": "string",
            "description": "Text prompt for image generation",
            "example": "A dark cyberpunk cityscape at night, neon lights, rain"
          },
          "model": {
            "type": "string",
            "description": "Model override (e.g. google/imagen-4, black-forest-labs/flux-dev, openai/dall-e-3)",
            "example": "google/imagen-4"
          },
          "enhance": {
            "type": "boolean",
            "description": "Enhance prompt via AI before generation",
            "example": true
          }
        }
      },
      "ImageResponse": {
        "type": "object",
        "properties": {
          "imageUrl": {
            "type": "string",
            "format": "uri",
            "example": "https://replicate.delivery/.../output.png"
          },
          "provider": {
            "type": "string",
            "example": "replicate"
          },
          "model": {
            "type": "string",
            "example": "google/imagen-4"
          }
        }
      },
      "TtsRequest": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": {
            "type": "string",
            "maxLength": 1000,
            "description": "Text to synthesize",
            "example": "Bonjour, bienvenue dans l'univers DarkMedia-X."
          },
          "voice": {
            "type": "string",
            "description": "Voice ID (provider-specific)",
            "example": "alloy"
          },
          "model": {
            "type": "string",
            "description": "TTS model override (e.g. resemble-ai/chatterbox, elevenlabs/eleven-turbo-v2)",
            "example": "resemble-ai/chatterbox"
          }
        }
      },
      "TtsResponse": {
        "type": "object",
        "properties": {
          "audio": {
            "type": "string",
            "description": "Base64-encoded audio data",
            "example": "//uQZ..."
          },
          "contentType": {
            "type": "string",
            "example": "audio/wav"
          }
        }
      },
      "VideoRequest": {
        "type": "object",
        "properties": {
          "prompt": {
            "type": "string",
            "description": "Text prompt for video generation",
            "example": "A cinematic horror scene, dark atmosphere, fog"
          },
          "image_url": {
            "type": "string",
            "format": "uri",
            "description": "Source image for image-to-video",
            "example": "https://example.com/source-image.jpg"
          },
          "model": {
            "type": "string",
            "description": "Model override (default: minimax/video-01)",
            "example": "minimax/video-01"
          },
          "enhance": {
            "type": "boolean",
            "description": "Enhance prompt via AI before generation",
            "example": true
          }
        }
      },
      "VideoResponse": {
        "type": "object",
        "properties": {
          "videoUrl": {
            "type": "string",
            "format": "uri",
            "example": "https://replicate.delivery/.../output.mp4"
          },
          "provider": {
            "type": "string",
            "example": "replicate"
          },
          "model": {
            "type": "string",
            "example": "minimax/video-01"
          }
        }
      }
    }
  },
  "paths": {
    "/api/health": {
      "get": {
        "tags": ["System"],
        "summary": "Health Check",
        "description": "Returns the service status and active providers.",
        "responses": {
          "200": {
            "description": "Service is operational",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "ok": { "type": "boolean", "example": true },
                            "service": { "type": "string", "example": "ai-smart-router" },
                            "providers": {
                              "type": "array",
                              "items": { "type": "string" },
                              "example": ["openrouter", "replicate"]
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/chat": {
      "post": {
        "tags": ["AI Operations"],
        "summary": "Chat Completion",
        "description": "Route a chat request to an AI provider with fallback logic. OpenRouter is the default provider. If a model reaches its limit (429/quota), cheaper fallback models are tried automatically before switching provider.",
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ChatRequest" },
              "example": {
                "messages": [
                  { "role": "user", "content": "Explique les microservices en une phrase." }
                ],
                "model": "meta-llama/llama-3.1-70b-instruct"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/ChatResponse" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/normalize": {
      "post": {
        "tags": ["AI Operations"],
        "summary": "Text Normalization",
        "description": "Extract structured data from free-text.",
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/NormalizeRequest" },
              "example": {
                "text": "L'utilisateur Jean Dupont a fini son test avec 85% aujourd'hui le 13 mars 2026."
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Data successfully extracted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/image": {
      "post": {
        "tags": ["Media Generation"],
        "summary": "Generate Image",
        "description": "Generate an image from a text prompt using Replicate (free models first) with OpenRouter fallback.",
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ImageRequest" },
              "example": {
                "prompt": "A dark cyberpunk cityscape at night, neon lights, rain",
                "model": "google/imagen-4",
                "enhance": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Image generated",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/ImageResponse" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/tts": {
      "post": {
        "tags": ["Media Generation"],
        "summary": "Text-to-Speech",
        "description": "Synthesize speech from text using Replicate (free models first) with OpenRouter fallback.",
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TtsRequest" },
              "example": {
                "text": "Bonjour, bienvenue dans l'univers DarkMedia-X.",
                "voice": "alloy",
                "model": "resemble-ai/chatterbox"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Audio generated",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/TtsResponse" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "503": {
            "description": "No TTS provider configured",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/video": {
      "post": {
        "tags": ["Media Generation"],
        "summary": "Generate Video",
        "description": "Generate a video from text or image using Replicate (free models first) with Fal.ai fallback.",
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/VideoRequest" },
              "example": {
                "prompt": "A cinematic horror scene, dark atmosphere, fog",
                "model": "minimax/video-01",
                "enhance": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Video generated",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/VideoResponse" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "503": {
            "description": "No video provider configured",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    }
  }
}
