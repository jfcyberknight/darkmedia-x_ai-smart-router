# Secret pour restreindre l'accès à l'API (toi uniquement). Min. 8 caractères.
# En-tête : Authorization: Bearer <API_SECRET> ou X-API-Key: <API_SECRET>
API_SECRET=

# --- GOOGLE OAUTH & SESSION ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OWNER_EMAIL=
JWT_SECRET=
AUTH_PROVIDER_API_KEY=

# Clés API des providers (au moins une requise)
# Toute variable listée ici sera poussée vers Vercel par npm run env:push si elle est définie dans .env

# Créer une clé : https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Créer une clé : https://console.groq.com/keys
GROQ_API_KEY=

# Ajoutez ici toute nouvelle clé (ex: OPENAI_API_KEY=), puis la valeur dans .env, et lancez npm run env:push
# Ajoutées par env:sync
NVAPI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
# Ajoutées par env:sync
AI_SMART_ROUTER_URL=
ANTHROPIC_API_KEY=
RENDERER_ENGINE=
IMAGE_GEN_MODE=
VOICE_GEN_MODE=
QDRANT_URL=
QDRANT_API_KEY=
HF_HUB_DISABLE_SYMLINKS_WARNING=
CLIENT_KEY_AI_SMART_ROUTER=
SERVER_SECRET_AI_SMART_ROUTER=
RAG_API_URL=
CLIENT_API_RAG=
SERVER_SECRET_RAG=
GITHUB_TOKEN=
FAL_KEY=

# TTS Providers (optionnel - si configuré, /api/tts sera actif)
# ElevenLabs (prioritaire) : https://console.elevenlabs.io
ELEVENLABS_API_KEY=

# Together.ai (fallback) : https://api.together.ai
TOGETHER_API_KEY=

# OpenRouter TTS / Coqui (fallback)
OPENROUTER_API_KEY=
TTS_API_KEY=
TTS_API_URL= (Update .env.example and add api/tts.js)
# Ajoutées par env:sync
CLOUDFLARE_API_KEY=
