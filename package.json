{
  "name": "darkmedia-x-ai-smart-router",
  "version": "2.0.26",
  "workspaces": [
    "ai-smart-router"
  ],
  "description": "API Vercel qui route les requêtes IA vers Gemini, Groq et autres providers avec fallback automatique",
  "main": "lib/router.js",
  "scripts": {
    "dev": "vercel dev",
    "deploy": "vercel --prod",
    "prepare": "node scripts/install-git-hooks.js",
    "env:push": "node scripts/vercel-env-push.js",
    "env:push:root": "node scripts/vercel-env-push.js .env",
    "env:sync": "node scripts/env-sync.js",
    "env:sync:force": "node scripts/env-sync.js --force",
    "test": "node --test tests/validate-chat.test.js tests/auth.test.js tests/router.test.js tests/providers.test.js tests/deployed.test.js",
    "test:deployed": "node --test tests/deployed.test.js",
    "test:providers": "node scripts/test-providers.js",
    "test:api": "node scripts/test-api.js",
    "test:api:prod": "node scripts/test-api-deployed.js",
    "rag:index": "python index_rag.py",
    "rag:push": "python push.py",
    "rag:status": "rag status",
    "rag:search": "rag search"
  },
  "keywords": [
    "ai",
    "vercel",
    "gemini",
    "groq",
    "router",
    "api"
  ],
  "author": "Darkmedia-X",
  "license": "ISC",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cookie": "^1.1.1",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3"
  }
}
