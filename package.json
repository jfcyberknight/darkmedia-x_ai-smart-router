{
  "name": "darkmedia-x-ai-smart-router",
  "version": "2.0.26",
  "workspaces": [
    "ai-smart-router"
  ],
  "description": "API Vercel qui route les requêtes IA vers Gemini, Groq et autres providers avec fallback automatique",
  "main": "ai-smart-router/router.js",
  "scripts": {
    "dev": "cd ai-smart-router && vercel dev",
    "deploy": "cd ai-smart-router && vercel --prod",
    "prepare": "cd ai-smart-router && node scripts/install-git-hooks.js",
    "env:push": "cd ai-smart-router && node scripts/vercel-env-push.js",
    "env:sync": "cd ai-smart-router && node scripts/env-sync.js",
    "test": "cd ai-smart-router && node --test tests/validate-chat.test.js tests/auth.test.js",
    "test:providers": "cd ai-smart-router && node scripts/test-providers.js",
    "test:api": "cd ai-smart-router && node scripts/test-api.js",
    "test:api:prod": "cd ai-smart-router && node scripts/test-api-deployed.js"
  },
  "keywords": ["ai", "vercel", "gemini", "groq", "router", "api"],
  "author": "Darkmedia-X",
  "license": "ISC",
  "engines": {
    "node": ">=18"
  }
}
